# ─── Stripe ────────────────────────────────────────────────────────────────────
# Server-side secret key (Dashboard → Developers → API keys → Secret key)
STRIPE_SECRET_KEY=sk_live_...

# Client-side publishable key (Dashboard → Developers → API keys → Publishable key)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── EmailJS ───────────────────────────────────────────────────────────────────
# Account → Email Services → your service → Service ID
EMAILJS_SERVICE_ID=service_xxxxxxx

# Account → Email Templates → your template → Template ID
EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Account → Account → Public Key
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxx

# Account → Account → Private Key (optional, for server-side sending)
EMAILJS_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxx

# ─── Sanity ────────────────────────────────────────────────────────────────────
# manage.sanity.io → your project → Settings → API → Project ID
SANITY_PROJECT_ID=xxxxxxxx

# manage.sanity.io → your project → Settings → API → Tokens → Add API token (Editor role)
SANITY_API_TOKEN=skxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── App ───────────────────────────────────────────────────────────────────────
JWT_SECRET=ein-langes-zufaelliges-geheimnis-min-32-zeichen
NODE_ENV=production
